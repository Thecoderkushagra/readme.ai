# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.java text diff=java
*.ts text
*.tsx text
*.js text
*.json text
*.yml text
*.yaml text
*.md text
*.xml text
*.properties text
*.env.*.example text
*.editorconfig text
*.gitignore text
*.gitattributes text
Dockerfile text

# Scripts requiring specific line endings
mvnw text eol=lf
*.sh text eol=lf
mvnw.cmd text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary file handling
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.class binary

